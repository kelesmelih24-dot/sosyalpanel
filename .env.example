# Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase Project Settings -> API -> service_role (SECRET — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your production domain (used to build correct social share image URLs)
NEXT_PUBLIC_SITE_URL=https://sosyalpanel.com

# Telegram bot notification — you get a message the instant a customer uploads
# a payment receipt. See README "Telegram bildirimi kurulumu" for how to get
# your chat ID if you already have a bot token but not the chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Secret used to protect the /api/cron/sync-orders endpoint from public access.
# Generate any random string and set the same value in Vercel's Cron Job config.
CRON_SECRET=

# Optional: Resend (https://resend.com) for order-status emails to customers.
# Leave empty to disable emails — nothing else breaks if unset.
# IMPORTANT: without a verified domain, Resend's sandbox "from" address
# (onboarding@resend.dev) can ONLY deliver to the email you signed up with —
# real customers using other email addresses won't receive anything until
# you verify a domain you own at https://resend.com/domains.
RESEND_API_KEY=
RESEND_FROM_EMAIL=SosyalPanel <onboarding@resend.dev>

# Optional: a Slack/Discord webhook URL to receive low-provider-balance alerts.
ALERT_WEBHOOK_URL=

# Groq API key — powers the AI review moderation, AI live chat widget, and
# the "AI ile yaz" blog assistant in the admin panel. Genuinely free tier,
# no credit card required, no commercial-use restriction. Get one at
# https://console.groq.com. Leave empty to disable these AI features
# (reviews will simply not auto-publish, chat/blog-write will show a fallback message).
GROQ_API_KEY=

# Optional: Google Analytics 4 measurement ID (starts with G-). Create a NEW
# property for this site at https://analytics.google.com — don't reuse one
# tied to a different site.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: where to also send the weekly sales report email (Telegram always
# gets it regardless). Leave empty to skip the email copy.
ADMIN_REPORT_EMAIL=
