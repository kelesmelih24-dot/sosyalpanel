# Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase Project Settings -> API -> service_role (SECRET — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your production domain (used to build correct social share image URLs)
NEXT_PUBLIC_SITE_URL=https://sosyalpanel.com

# Cloudflare Turnstile (bot/captcha protection on registration) — optional but recommended.
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# Also paste the secret key into Supabase Dashboard -> Authentication -> Attack Protection -> Captcha.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Secret used to protect the /api/cron/sync-orders endpoint from public access.
# Generate any random string and set the same value in Vercel's Cron Job config.
CRON_SECRET=

# Optional: Resend (https://resend.com) for order-status emails to customers.
# Leave empty to disable emails — nothing else breaks if unset.
RESEND_API_KEY=
RESEND_FROM_EMAIL=SosyalPanel <bildirim@senin-domainin.com>

# Optional: a Slack/Discord/Telegram webhook URL to receive low-provider-balance alerts.
ALERT_WEBHOOK_URL=
